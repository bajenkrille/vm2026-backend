generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model deltagare {
  id                                    BigInt           @id @default(autoincrement())
  first_name                            String?          @db.VarChar(255)
  last_name                             String?          @db.VarChar(255)
  nick_name                             String           @unique(map: "unique_nick_name") @db.VarChar(255)
  email                                 String?          @db.VarChar(255)
  phone_number                          String?          @db.VarChar(255)
  password                              String?          @db.VarChar(255)
  has_paid                              Boolean?
  liga_deltagare                        liga_deltagare[]
  match_tips                            match_tips[]
  points_points_deltagare_idTodeltagare points[]         @relation("points_deltagare_idTodeltagare")
  reset_tokens                          reset_tokens[]
}

model liga {
  id             BigInt           @id @default(autoincrement())
  liga_name      String?          @db.VarChar(255)
  description    String?          @db.VarChar(255)
  liga_deltagare liga_deltagare[]
}

model liga_deltagare {
  liga_id      BigInt
  deltagare_id BigInt
  deltagare    deltagare @relation(fields: [deltagare_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "deltagare_join_fk")
  liga         liga      @relation(fields: [liga_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "liga_join_fk")

  @@id([liga_id, deltagare_id])
  @@index([deltagare_id], map: "deltagare_join_fk")
}

model match_tips {
  id           BigInt    @id @default(autoincrement())
  hemma_mal    Int?
  borta_mal    Int?
  deltagare_id BigInt
  matchen_id   BigInt
  deltagare    deltagare @relation(fields: [deltagare_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "match_tips_deltagare_fk")
  matchen      matchen   @relation(fields: [matchen_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "match_tips_matchen_fk")
  points       points[]

  @@unique([deltagare_id, matchen_id], map: "unique_deltagare_matchen")
  @@index([deltagare_id], map: "match_tips_deltagare_fk")
  @@index([matchen_id], map: "match_tips_matchen_fk")
}

model matchen {
  id         BigInt       @id @default(autoincrement())
  hemma_lag  String?      @db.VarChar(255)
  borta_lag  String?      @db.VarChar(255)
  hemma_mal  Int?
  borta_mal  Int?
  played     Boolean?
  datum      String?      @db.VarChar(255)
  tid        String?      @db.VarChar(255)
  location   String?      @db.VarChar(255)
  grupp      String?      @db.VarChar(255)
  match_tips match_tips[]
}

model points {
  id                                       BigInt     @id @default(autoincrement())
  points                                   Int?
  match_tips_id                            BigInt
  deltagare_id                             BigInt
  deltagare_points_deltagare_idTodeltagare deltagare  @relation("points_deltagare_idTodeltagare", fields: [deltagare_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "points_deltagare_fk")
  match_tips                               match_tips @relation(fields: [match_tips_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "points_match_tips_fk")

  @@index([deltagare_id], map: "points_deltagare_fk")
  @@index([match_tips_id], map: "points_match_tips_fk")
}

model reset_tokens {
  id         Int       @id @default(autoincrement())
  user_id    BigInt
  token_hash String    @unique(map: "token_hash") @db.VarChar(64)
  expires_at DateTime  @db.DateTime(0)
  used_at    DateTime? @db.DateTime(0)
  created_at DateTime  @default(now()) @db.DateTime(0)
  deltagare  deltagare @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reset_tokens_ibfk_1")

  @@index([user_id], map: "user_id")
}
